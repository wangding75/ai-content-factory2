{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://ai-content-factory.local/schemas/content-packs/novel/content-version.schema.json","title":"Novel Content Version","type":"object","additionalProperties":false,"required":["id","content_item_id","title","content","summary","word_count","source","version_no","version","status","created_at","updated_at","frozen_at"],"properties":{"id":{"type":"string","format":"uuid"},"content_item_id":{"type":"string","format":"uuid"},"title":{"type":"string","minLength":1,"maxLength":120},"content":{"type":"string","maxLength":200000},"summary":{"type":["string","null"],"maxLength":5000},"word_count":{"type":"integer","minimum":0},"source":{"type":"string","enum":["manual_created","mock_generated","mock_rewrite"]},"version_no":{"type":"integer","minimum":1},"version":{"type":"integer","minimum":1},"status":{"type":"string","enum":["editable_draft","frozen"]},"created_at":{"type":"string","format":"date-time"},"updated_at":{"type":"string","format":"date-time"},"frozen_at":{"type":["string","null"],"format":"date-time"}},"description":"version is optimistic lock; expected_version is request-only. Iteration 06 defines v1; Iteration 07.1A additionally permits only v2 source=mock_rewrite, initially editable_draft, without changing ContentItem.current_version_id. Null summary clears; empty string is retained."}

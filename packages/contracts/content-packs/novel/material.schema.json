{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-content-factory.local/schemas/content-packs/novel/material.schema.json",
  "title": "Novel Material",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "name", "summary", "content_json", "tags_json"],
  "properties": {
    "type": {"type": "string", "enum": ["character", "worldview", "location", "organization", "item", "reference"]},
    "name": {"type": "string", "minLength": 1, "maxLength": 120},
    "summary": {"type": "string", "maxLength": 5000},
    "content_json": {"type": "object", "additionalProperties": true},
    "tags_json": {"type": "array", "maxItems": 20, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 50}}
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"const": "character"}}, "required": ["type"]},
      "then": {
        "properties": {
          "content_json": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "age": {"type": "string", "maxLength": 50},
              "personality": {"type": "string", "maxLength": 2000},
              "background": {"type": "string", "maxLength": 5000},
              "appearance": {"type": "string", "maxLength": 2000}
            }
          }
        }
      }
    }
  ]
}
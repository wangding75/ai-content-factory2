APP_ENV=development

API_PORT=8080
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

POSTGRES_DB=acf
POSTGRES_USER=acf
POSTGRES_PASSWORD=acf
DATABASE_URL=postgres://acf:acf@localhost:5432/acf?sslmode=disable
# Required by the API to encrypt saved configuration credentials. Use a unique secret outside source control.
CONFIGURATION_ENCRYPTION_KEY=replace-with-a-local-development-secret

REDIS_URL=redis://localhost:6379/0

WORKFLOW_PROVIDER=mock
CONTENT_PACKS=novel

LOG_LEVEL=info
